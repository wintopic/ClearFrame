def system_proxy_map():
    try:
        import gi

        gi.require_version("Gio", "2.0")
        from gi.repository import Gio
    except Exception:
        return {}

    source = Gio.SettingsSchemaSource.get_default()
    if source is None or source.lookup("org.gnome.system.proxy", True) is None:
        return {}

    proxy_settings = Gio.Settings.new("org.gnome.system.proxy")
    if proxy_settings.get_string("mode") != "manual":
        return {}

    proxies = {}
    for scheme, schema_id in (
        ("http", "org.gnome.system.proxy.http"),
        ("https", "org.gnome.system.proxy.https"),
    ):
        if source.lookup(schema_id, True) is None:
            continue
        settings = Gio.Settings.new(schema_id)
        host = settings.get_string("host")
        port = settings.get_int("port")
        if not host or port <= 0:
            continue

        userinfo = ""
        if schema_id.endswith(".http") and settings.get_boolean("use-authentication"):
            user = urllib.parse.quote(settings.get_string("authentication-user"), safe="")
            password = urllib.parse.quote(settings.get_string("authentication-password"), safe="")
            if user:
                userinfo = f"{user}:{password}@"

        proxies[scheme] = f"{scheme}://{userinfo}{host}:{port}"

    return proxies


def url_opener():
    proxies = urllib.request.getproxies()
    proxies.update(system_proxy_map())
    handlers = [urllib.request.ProxyHandler(proxies)] if proxies else []
    return urllib.request.build_opener(*handlers)


def request_headers():
    return {
        "Accept": "application/vnd.github+json",
        "User-Agent": APP_USER_AGENT,
        "X-GitHub-Api-Version": "2022-11-28",
    }


def normalized_version(value):
    match = re.search(r"(\d+(?:\.\d+)*)", value or "")
    if not match:
        return ()
    return tuple(int(part) for part in match.group(1).split("."))


def newer_version(remote, local=APP_VERSION):
    remote_parts = normalized_version(remote)
    local_parts = normalized_version(local)
    width = max(len(remote_parts), len(local_parts))
    return remote_parts + (0,) * (width - len(remote_parts)) > local_parts + (0,) * (width - len(local_parts))


def safe_download_name(name):
    cleaned = re.sub(r"[^A-Za-z0-9._-]+", "-", name or "").strip(".-")
    return cleaned or f"{APP_REPOSITORY_NAME}.zip"


def unique_path(path):
    if not path.exists():
        return path
    stem = path.stem
    suffix = path.suffix
    for index in range(1, 1000):
        candidate = path.with_name(f"{stem}-{index}{suffix}")
        if not candidate.exists():
            return candidate
    raise RuntimeError(tr("无法生成下载文件名", "Could not create a download filename"))


def latest_release():
    request = urllib.request.Request(APP_LATEST_RELEASE_API, headers=request_headers())
    try:
        with url_opener().open(request, timeout=15) as response:
            data = json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as error:
        if error.code == 404:
            return None
        raise RuntimeError(f"HTTP {error.code}: {error.reason}") from error

    tag = data.get("tag_name") or data.get("name") or ""
    assets = data.get("assets") or []
    asset = next((item for item in assets if item.get("browser_download_url")), None)
    download_url = asset.get("browser_download_url") if asset else data.get("zipball_url")
    file_name = asset.get("name") if asset else f"{APP_REPOSITORY_NAME}-{tag or 'latest'}.zip"
    return {
        "tag": tag,
        "version": normalized_version(tag) and tag.lstrip("vV") or tag,
        "html_url": data.get("html_url") or f"{APP_REPOSITORY_URL}/releases/latest",
        "download_url": download_url,
        "file_name": safe_download_name(file_name),
    }


def download_release(release):
    download_url = release.get("download_url")
    if not download_url:
        raise RuntimeError(tr("没有可下载的更新文件。", "No downloadable update file is available."))

    target_dir = Path.home() / "Downloads"
    target_dir.mkdir(parents=True, exist_ok=True)
    target = unique_path(target_dir / safe_download_name(release.get("file_name")))
    request = urllib.request.Request(download_url, headers=request_headers())
    with url_opener().open(request, timeout=60) as response, target.open("wb") as output:
        shutil.copyfileobj(response, output)
    return target


def clamp(value, minimum=0.0, maximum=1.0):
    return max(minimum, min(maximum, float(value)))


def schema_exists(schema):
    result = run(["gsettings", "list-schemas"])
    return schema in result.stdout.splitlines()


def gsettings_get(schema, key, fallback=None):
    result = run(["gsettings", "get", schema, key])
    if result.returncode != 0:
        return fallback
    return result.stdout.strip()


def gsettings_set(schema, key, value):
    return run(["gsettings", "set", schema, key, str(value)]).returncode == 0


def gsettings_reset(schema, key):
    run(["gsettings", "reset", schema, key])


def compile_schemas(schema_dir):
    if schema_dir.exists() and shutil.which("glib-compile-schemas"):
        run(["glib-compile-schemas", str(schema_dir)], check=True)


def ensure_source_schemas():
    compile_schemas(EXT_SRC / "schemas")


def same_path(left, right):
    try:
        return left.resolve() == right.resolve()
    except FileNotFoundError:
        return False


def install_app_icon():
    if not APP_ICON_SRC.exists():
        return

    icon_dir = ICON_THEME_DIR / "512x512/apps"
    icon_dir.mkdir(parents=True, exist_ok=True)
    icon_file = icon_dir / f"{APP_ID}.png"

    try:
        from PIL import Image, ImageDraw
    except ImportError:
        shutil.copy2(APP_ICON_SRC, icon_file)
        return

    image = Image.open(APP_ICON_SRC).convert("RGBA")
    width, height = image.size
    side = min(width, height)
    left = (width - side) // 2
    top = (height - side) // 2
    image = image.crop((left, top, left + side, top + side))
    image = image.resize((APP_ICON_SIZE, APP_ICON_SIZE), Image.Resampling.LANCZOS)

    mask = Image.new("L", (APP_ICON_SIZE, APP_ICON_SIZE), 0)
    draw = ImageDraw.Draw(mask)
    draw.rounded_rectangle(
        (0, 0, APP_ICON_SIZE - 1, APP_ICON_SIZE - 1),
        radius=APP_ICON_RADIUS,
        fill=255,
    )
    image.putalpha(mask)
    image.save(icon_file, "PNG", optimize=True)


