def install_app_files():
    if same_path(BASE_DIR, APP_INSTALL_DIR):
        return

    if APP_INSTALL_DIR.exists():
        shutil.rmtree(APP_INSTALL_DIR)
    APP_INSTALL_DIR.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(
        BASE_DIR,
        APP_INSTALL_DIR,
        ignore=shutil.ignore_patterns("__pycache__", "gschemas.compiled", ".git"),
    )


def load_settings():
    import gi

    gi.require_version("Gio", "2.0")
    from gi.repository import Gio

    ensure_source_schemas()
    schema_dir = EXT_DST / "schemas"
    if not (schema_dir / "gschemas.compiled").exists():
        schema_dir = EXT_SRC / "schemas"

    source = Gio.SettingsSchemaSource.new_from_directory(
        str(schema_dir),
        Gio.SettingsSchemaSource.get_default(),
        False,
    )
    schema = source.lookup(SCHEMA_ID, False)
    if schema is None:
        raise RuntimeError(tr(f"找不到设置 schema: {SCHEMA_ID}", f"Could not find settings schema: {SCHEMA_ID}"))
    return Gio.Settings.new_full(schema, None, None)


def enabled_extensions():
    raw = gsettings_get("org.gnome.shell", "enabled-extensions", "[]")
    try:
        value = ast.literal_eval(raw)
    except Exception:
        return []
    return value if isinstance(value, list) else []


def set_enabled_extension(uuid, enabled):
    items = enabled_extensions()
    if enabled and uuid not in items:
        items.append(uuid)
    if not enabled:
        items = [item for item in items if item != uuid]
    gsettings_set("org.gnome.shell", "enabled-extensions", repr(items))


def shell_knows_extension(uuid=EXT_UUID):
    return run(["gnome-extensions", "info", uuid]).returncode == 0


def shell_extension_should_run(settings):
    return (
        settings.get_boolean("topbar-enabled")
        or settings.get_boolean("window-enabled")
    )


def sync_shell_extension(settings):
    active = shell_extension_should_run(settings)
    set_enabled_extension(EXT_UUID, active)
    if shell_knows_extension():
        action = "enable" if active else "disable"
        result = run(["gnome-extensions", action, EXT_UUID])
        return result.returncode == 0
    return False


def extension_needs_install():
    if not (EXT_DST / "metadata.json").exists():
        return True
    if not (EXT_DST / "schemas" / "gschemas.compiled").exists():
        return True

    for relative_path in EXT_SYNC_FILES:
        source = EXT_SRC / relative_path
        target = EXT_DST / relative_path
        if not target.exists() or not filecmp.cmp(source, target, shallow=False):
            return True
    return False


def ensure_extension_installed():
    if extension_needs_install():
        install_extension()


def install_extension():
    ensure_source_schemas()
    install_app_icon()
    if EXT_DST.exists():
        shutil.rmtree(EXT_DST)
    EXT_DST.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(EXT_SRC, EXT_DST)
    write_extension_metadata(EXT_DST / "metadata.json")
    compile_schemas(EXT_DST / "schemas")

    refresh_desktop_caches()


def install_all():
    install_app_files()
    install_app_icon()
    install_desktop_entry()
    install_extension()
    sync_shell_extension(load_settings())


def set_topbar(enabled, transparency=None):
    ensure_extension_installed()
    settings = load_settings()
    if transparency is not None:
        settings.set_double("topbar-opacity", clamp(transparency))
    settings.set_boolean("topbar-enabled", bool(enabled))

    return sync_shell_extension(settings)


def set_window_transparency(enabled, transparency=None):
    ensure_extension_installed()
    settings = load_settings()
    if transparency is not None:
        settings.set_double("window-opacity", clamp(transparency))
    settings.set_boolean("window-enabled", bool(enabled))

    return sync_shell_extension(settings)


def dock_supported():
    return schema_exists("org.gnome.shell.extensions.dash-to-dock")


def dock_transparency():
    if not dock_supported():
        return 0.0
    raw = gsettings_get("org.gnome.shell.extensions.dash-to-dock", "background-opacity", "1.0")
    try:
        return clamp(1.0 - float(raw))
    except ValueError:
        return 0.0


def dock_enabled():
    if not dock_supported():
        return False
    mode = gsettings_get("org.gnome.shell.extensions.dash-to-dock", "transparency-mode", "")
    return mode == "'FIXED'" and dock_transparency() > 0


def saved_dock_transparency(fallback=1.0):
    try:
        ensure_extension_installed()
        return clamp(load_settings().get_double("dock-opacity"))
    except Exception:
        return clamp(fallback)


def save_dock_transparency(transparency):
    try:
        ensure_extension_installed()
        load_settings().set_double("dock-opacity", clamp(transparency))
    except Exception:
        pass


def set_dock(enabled, transparency=None):
    if not dock_supported():
        return False
    if enabled:
        value = saved_dock_transparency(dock_transparency()) if transparency is None else clamp(transparency)
        save_dock_transparency(value)
        gsettings_set("org.gnome.shell.extensions.dash-to-dock", "transparency-mode", "'FIXED'")
        gsettings_set("org.gnome.shell.extensions.dash-to-dock", "background-opacity", 1.0 - value)
    else:
        gsettings_reset("org.gnome.shell.extensions.dash-to-dock", "transparency-mode")
        gsettings_reset("org.gnome.shell.extensions.dash-to-dock", "background-opacity")
    return True


def remove_stale_titlebar_block(text):
    stripped = STALE_TITLEBAR_RE.sub("\n", text).strip()
    return stripped + ("\n" if stripped else "")


def cleanup_titlebar_css():
    for gtk_dir in (Path.home() / ".config/gtk-3.0", Path.home() / ".config/gtk-4.0"):
        gtk_dir.mkdir(parents=True, exist_ok=True)
        css_file = gtk_dir / "gtk.css"
        current = css_file.read_text(encoding="utf-8") if css_file.exists() else ""
        updated = remove_stale_titlebar_block(current)
        css_file.write_text(updated, encoding="utf-8")


def window_state():
    settings = load_settings()
    return settings.get_boolean("window-enabled"), settings.get_double("window-opacity")


def enable_all():
    set_dock(True, 1.0)
    set_window_transparency(False)
    topbar_live = set_topbar(True, 1.0)
    cleanup_titlebar_css()
    message = tr(
        "已开启 Dock 和顶栏透明，窗口整体透明保持关闭。",
        "Dock and top bar transparency are on. Whole-window transparency remains off.",
    )
    if not topbar_live:
        message += tr(
            " 顶栏首次安装可能需要注销并重新登录。",
            " You may need to log out and back in the first time the top bar extension is installed.",
        )
    notify(message)
    print(message)


def disable_all():
    set_dock(False)
    set_window_transparency(False)
    set_topbar(False)
    cleanup_titlebar_css()
    message = tr("已关闭透明效果。", "Transparency effects are off.")
    notify(message)
    print(message)


def print_status():
    settings = load_settings()
    enabled = tr("开", "on")
    disabled = tr("关", "off")
    yes = tr("是", "yes")
    no = tr("否", "no")
    print(f"Dock: {enabled if dock_enabled() else disabled} {dock_transparency():.2f}")
    print(f"{tr('顶栏', 'Top bar')}: {enabled if settings.get_boolean('topbar-enabled') else disabled} {settings.get_double('topbar-opacity'):.2f}")
    print(f"{tr('窗口', 'Window')}: {enabled if settings.get_boolean('window-enabled') else disabled} {settings.get_double('window-opacity'):.2f}")
    print(f"{tr('Shell 已识别扩展', 'Shell extension known')}: {yes if shell_knows_extension() else no}")


def launch_gui():
    warnings.filterwarnings(
        "ignore",
        category=DeprecationWarning,
        message=r".*Adw\.PreferencesWindow\.add.*",
    )
    warnings.filterwarnings(
        "ignore",
        category=DeprecationWarning,
        message=r".*Adw\.AboutWindow\..*",
    )

    import gi

    gi.require_version("Gtk", "4.0")
    gi.require_version("Adw", "1")
    from gi.repository import Adw, Gdk, Gio, GLib, Gtk

    class ClearFrameApp(Adw.Application):
        def __init__(self):
            super().__init__(application_id=APP_ID, flags=Gio.ApplicationFlags.DEFAULT_FLAGS)
            self._updating = False
            self._settings = None
            self._dock_scale = None
            self._styles_installed = False
            self._status_title_label = None
            self._status_subtitle_label = None
            self._status_metric_items = []
            self._status_icon_ring = None
            self._status_icon = None
            self._status_watermark_icon = None
            self._toast_overlay = None
            self._update_button = None
            self._window = None

        def do_activate(self):
            self._install_styles()
            ensure_extension_installed()
            self._settings = load_settings()
            sync_shell_extension(self._settings)

