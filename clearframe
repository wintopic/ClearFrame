APP_TITLE = APP_NAME_ZH if USE_ZH else APP_NAME_EN


def tr(zh, en):
    return zh if USE_ZH else en


def run(argv, check=False):
    return subprocess.run(argv, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=check)


def notify(message):
