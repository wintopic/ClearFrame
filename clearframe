        def _menu_action_button(self, label, icon_name, callback):
            button = Gtk.Button()
            button.set_halign(Gtk.Align.FILL)
            content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            image = self._icon_image(icon_name, 18)
            image.add_css_class("clearframe-menu-icon")
