        def _install_styles(self):
            if self._styles_installed:
                return
            display = Gdk.Display.get_default()
            if display is None:
                return
            provider = Gtk.CssProvider()
            provider.load_from_data(CLEARFRAME_GUI_CSS.encode("utf-8"))
            Gtk.StyleContext.add_provider_for_display(
                display,
                provider,
                Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
            )
            self._styles_installed = True

        def _icon_image(self, name, pixel_size):
            image = Gtk.Image.new_from_file(str(ui_icon_path(name)))
            image.set_pixel_size(pixel_size)
