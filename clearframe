        def _language_changed(self, dropdown, _pspec):
            languages = ("system", "zh", "en")
            selected = dropdown.get_selected()
            if selected >= len(languages):
                return

            language = languages[selected]
            config = load_config()
            if config.get("language", "system") == language:
                return

            config["language"] = language
            save_config(config)
            self._show_message(
                tr("语言已保存", "Language Saved"),
                tr("重新打开透界后会应用新的语言。", "Restart ClearFrame to apply the new language."),
            )

        def _show_about(self):
            about = Adw.AboutWindow(transient_for=self._window, modal=True)
            about.set_application_name(APP_TITLE)
            about.set_application_icon(APP_ID)
            about.set_version(APP_VERSION)
            about.set_developer_name(APP_REPOSITORY_OWNER)
            about.set_developers([APP_REPOSITORY_OWNER])
            about.set_comments(tr(APP_COMMENT_ZH, APP_COMMENT_EN))
            about.set_website(APP_REPOSITORY_URL)
            about.set_issue_url(f"{APP_REPOSITORY_URL}/issues")
            about.set_license_type(Gtk.License.MIT_X11)
            about.present()

        def _show_message(self, heading, body):
            dialog = Adw.MessageDialog(transient_for=self._window, modal=True, heading=heading, body=body)
            dialog.add_response("ok", tr("知道了", "OK"))
            dialog.set_default_response("ok")
            dialog.present()

        def _add_toast(self, message):
            if self._toast_overlay:
                self._toast_overlay.add_toast(Adw.Toast.new(message))

        def _check_updates(self):
            if self._update_button:
                self._update_button.set_sensitive(False)
            self._add_toast(tr("正在检测更新...", "Checking for updates..."))
            threading.Thread(target=self._check_updates_worker, daemon=True).start()

        def _check_updates_worker(self):
            try:
                release = latest_release()
                error = None
            except Exception as exc:
                release = None
                error = str(exc)
            GLib.idle_add(self._finish_update_check, release, error)

        def _finish_update_check(self, release, error):
            if self._update_button:
                self._update_button.set_sensitive(True)
            if error:
                self._show_message(tr("更新检查失败", "Update Check Failed"), error)
            elif release is None:
                self._show_message(
                    tr("暂无发布版本", "No Release Found"),
                    tr("当前仓库还没有可用于应用更新的 GitHub Release。", "This repository has no GitHub Release available for app updates yet."),
                )
            elif newer_version(release.get("version") or release.get("tag")):
                self._show_update_dialog(release)
            else:
                self._show_message(
                    tr("已经是最新版本", "Already Up to Date"),
                    tr(f"当前版本 {APP_VERSION}。", f"Current version is {APP_VERSION}."),
                )
            return GLib.SOURCE_REMOVE

        def _show_update_dialog(self, release):
            version = release.get("version") or release.get("tag") or tr("新版本", "New version")
            dialog = Adw.MessageDialog(
                transient_for=self._window,
                modal=True,
                heading=tr("发现新版本", "Update Available"),
                body=tr(
                    f"当前版本 {APP_VERSION}，最新版本 {version}。\n{release.get('html_url', APP_REPOSITORY_URL)}",
                    f"Current version is {APP_VERSION}; latest version is {version}.\n{release.get('html_url', APP_REPOSITORY_URL)}",
                ),
            )
            dialog.add_response("later", tr("稍后", "Later"))
            dialog.add_response("download", tr("下载更新", "Download"))
            dialog.set_default_response("download")
            dialog.set_response_appearance("download", Adw.ResponseAppearance.SUGGESTED)
            dialog.connect("response", lambda _dialog, response: self._download_update(release) if response == "download" else None)
            dialog.present()

        def _download_update(self, release):
            if self._update_button:
                self._update_button.set_sensitive(False)
            self._add_toast(tr("正在下载更新...", "Downloading update..."))
            threading.Thread(target=self._download_update_worker, args=(release,), daemon=True).start()

        def _download_update_worker(self, release):
            try:
                target = download_release(release)
                error = None
            except Exception as exc:
                target = None
                error = str(exc)
            GLib.idle_add(self._finish_update_download, target, error)

        def _finish_update_download(self, target, error):
            if self._update_button:
                self._update_button.set_sensitive(True)
            if error:
                self._show_message(tr("下载失败", "Download Failed"), error)
            else:
                self._show_message(
                    tr("更新已下载", "Update Downloaded"),
                    tr(f"文件已保存到：{target}", f"Saved to: {target}"),
                )
            return GLib.SOURCE_REMOVE

        def _switch_row(self, title, active, callback):
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=18)
            row.add_css_class("clearframe-control-row")

            label = Gtk.Label(label=title, xalign=0)
            label.add_css_class("clearframe-control-label")
            label.set_hexpand(True)
            label.set_wrap(True)

            switch = Gtk.Switch(valign=Gtk.Align.CENTER)
            switch.add_css_class("clearframe-switch")
            switch.set_active(active)
            switch.connect("notify::active", lambda widget, _pspec: callback(widget.get_active()))

            row.append(label)
            row.append(switch)
            return row, switch

        def _scale_row(self, title, value, callback):
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=18)
            row.add_css_class("clearframe-control-row")

            label = Gtk.Label(label=title, xalign=0)
            label.add_css_class("clearframe-control-label")
            label.set_wrap(True)
            label.set_width_chars(12)

            scale = Gtk.Scale.new_with_range(Gtk.Orientation.HORIZONTAL, 0, 100, 1)
            scale.set_value(round(clamp(value) * 100))
            scale.set_draw_value(False)
            scale.set_hexpand(True)
            scale.set_size_request(190, -1)
            scale.add_css_class("clearframe-scale")

            value_label = Gtk.Label(label=str(round(clamp(value) * 100)))
            value_label.add_css_class("clearframe-control-value")
            value_label.set_width_chars(3)
            value_label.set_xalign(1)

            def value_changed(widget):
                value_label.set_label(str(round(widget.get_value())))
                callback(widget.get_value() / 100.0)

            scale.connect("value-changed", value_changed)
            row.append(label)
            row.append(scale)
            row.append(value_label)
            return row, scale

