        def _topbar_toggled(self, active):
            live = set_topbar(active, self._settings.get_double("topbar-opacity"))
            if active and not live:
                self._set_status(tr("顶栏扩展已启用，重新登录后生效", "Top bar extension enabled; log out and back in to apply"))
            else:
                self._set_status(tr("顶栏设置已更新", "Top bar settings updated"))

        def _topbar_opacity_changed(self, value):
            self._settings.set_double("topbar-opacity", clamp(value))
            if self._settings.get_boolean("topbar-enabled"):
                set_enabled_extension(EXT_UUID, True)
            self._set_status(tr("顶栏透明度已更新", "Top bar transparency updated"))

        def _window_toggled(self, active):
            live = set_window_transparency(active, self._settings.get_double("window-opacity"))
            if active and not live:
                self._set_status(tr("窗口整体透明已启用，重新登录后生效", "Whole-window transparency enabled; log out and back in to apply"))
            else:
                self._set_status(tr("窗口整体透明设置已更新", "Whole-window transparency settings updated"))

        def _window_opacity_changed(self, value):
            self._settings.set_double("window-opacity", clamp(value))
            if self._settings.get_boolean("window-enabled"):
                set_enabled_extension(EXT_UUID, True)
            self._set_status(tr("窗口整体透明度已更新", "Whole-window transparency updated"))

        def _set_status(self, prefix=None):
            known = shell_knows_extension()
            if known:
                title = tr("配置正确", "Configuration OK")
                subtitle = tr("Shell 已识别扩展，设置会实时生效", "Shell recognizes the extension; settings apply live")
                metrics = (
                    tr("透明度已应用", "Applied"),
                    tr("扩展已识别", "Extension OK"),
                    tr("实时生效", "Live"),
                )
                status_icon_name = "status-shield"
                metric_icon_name = "check-circle"
                watermark_icon_name = "check-watermark"
            else:
                title = tr("等待 Shell 识别", "Waiting for Shell")
                subtitle = tr("首次安装可能需要注销并重新登录", "Log out and back in after first install")
                metrics = (
                    tr("设置已保存", "Saved"),
                    tr("等待识别", "Waiting"),
                    tr("重登生效", "Relogin"),
                )
                status_icon_name = "warning-shield"
                metric_icon_name = "warning-circle"
                watermark_icon_name = "warning-watermark"
            if prefix:
                subtitle = f"{prefix} · {subtitle}"

            self._status_title_label.set_label(title)
            self._status_subtitle_label.set_label(subtitle)

            if self._status_icon_ring:
                if known:
                    self._status_icon_ring.remove_css_class("waiting")
                else:
                    self._status_icon_ring.add_css_class("waiting")

            if self._status_icon:
                self._set_icon_image(self._status_icon, status_icon_name, 70)

            if self._status_watermark_icon:
                self._set_icon_image(self._status_watermark_icon, watermark_icon_name, 118)

            for item, text in zip(self._status_metric_items, metrics):
                metric, metric_icon, metric_label = item
                self._set_icon_image(metric_icon, metric_icon_name, 24)
                metric_label.set_label(text)
                if known:
                    metric.remove_css_class("waiting")
                else:
                    metric.add_css_class("waiting")

    app = ClearFrameApp()
    return app.run([])


def main(argv=None):
    parser = argparse.ArgumentParser(description=APP_TITLE)
    parser.add_argument(
        "command",
        nargs="?",
        default="gui",
        choices=["gui", "install", "on", "off", "status", "window-on", "window-off"],
    )
    args = parser.parse_args(argv)

    if args.command == "gui":
        return launch_gui()
    if args.command == "install":
        install_all()
        print(tr("透界 已安装/刷新。", "ClearFrame installed/refreshed."))
        return 0
    if args.command == "on":
        enable_all()
        return 0
    if args.command == "off":
        disable_all()
        return 0
    if args.command == "window-on":
        live = set_window_transparency(True, 0.25)
        message = tr(
            "已开启窗口整体透明，透明度 0.25。",
            "Whole-window transparency is on at 0.25.",
        )
        if not live:
            message += tr(
                " 扩展首次安装可能需要注销并重新登录。",
                " You may need to log out and back in the first time the extension is installed.",
            )
        notify(message)
        print(message)
        return 0
    if args.command == "window-off":
        set_window_transparency(False)
        message = tr("已关闭窗口整体透明。", "Whole-window transparency is off.")
        notify(message)
        print(message)
        return 0
    if args.command == "status":
        print_status()
        return 0
    return 2


